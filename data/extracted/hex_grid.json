  "coordinate_system": {
    "format": "SCCRRR where S=section letter (A-E), CC=column (01-60), RR=row (01-33)",
    "examples": [
      "A0101",
      "B3025",
      "B0117",
      "C0716"
    ],
    "section_order": "A=west(Tunisia/Tripolitania), B=central(Cyrenaica/Tobruk), C=east(Egypt border), D=Egypt, E=deep Egypt/Nile"
  },
  "neighbor_directions": {
    "description": "Pointy-top hex neighbors for odd/even columns",
    "odd_column": [
      "N=(col,row-1)",
      "NE=(col+1,row-1)",
      "SE=(col+1,row)",
      "S=(col,row+1)",
      "SW=(col-1,row)",
      "NW=(col-1,row-1)"
    ],
    "even_column": [
      "N=(col,row-1)",
      "NE=(col+1,row)",
      "SE=(col+1,row+1)",
      "S=(col,row+1)",
      "SW=(col-1,row+1)",
      "NW=(col-1,row)"
    ]
  },
